# ---------------------------------------------------------------------------
# Copy to `.env` and adjust. Docker Compose reads this file automatically.
# ---------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_TIME_ZONE=Asia/Singapore
DJANGO_LOG_LEVEL=INFO

# CORS (React dashboard origin)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database (MySQL). Set USE_SQLITE=True to skip MySQL for quick local runs.
USE_SQLITE=False
MYSQL_DATABASE=patrol
MYSQL_USER=patrol
MYSQL_PASSWORD=patrol
MYSQL_ROOT_PASSWORD=rootpatrol
MYSQL_HOST=db
MYSQL_PORT=3306

# JWT lifetimes
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- Large Language Model (AI incident analysis) ---
# Leave LLM_API_KEY empty to run in deterministic MOCK mode (no external calls).
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEXT_MODEL=gpt-4o-mini
LLM_VISION_MODEL=gpt-4o-mini

# --- Frontend (Google Maps) ---
# Used by the React dashboard live map. Put this in frontend/.env as
# REACT_APP_GOOGLE_MAPS_API_KEY as well.
GOOGLE_MAPS_API_KEY=
